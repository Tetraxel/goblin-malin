{
    "name": "goblin-malin",
    "version": "0.1.13",
    "description": "A keyboard-driven terminal UI for downloading and tagging music tracks with metadata from Spotify and YouTube",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "imports": {
        "#base": "./src/base/index.ts",
        "#base/*": "./src/base/*.ts",
        "#components": "./src/components/index.ts",
        "#components/*": "./src/components/*.ts",
        "#constants": "./src/constants.ts",
        "#contexts": "./src/contexts/index.ts",
        "#contexts/*": "./src/contexts/*.ts",
        "#exceptions": "./src/exceptions/index.ts",
        "#exceptions/*": "./src/exceptions/*.ts",
        "#flows": "./src/flows/index.ts",
        "#flows/*": "./src/flows/*.ts",
        "#hooks": "./src/hooks/index.ts",
        "#hooks/*": "./src/hooks/*.ts",
        "#sessions": "./src/sessions/index.ts",
        "#sessions/*": "./src/sessions/*.ts",
        "#settings": "./src/settings/index.ts",
        "#settings/*": "./src/settings/*.ts",
        "#updater/*": "./src/updater/*.ts",
        "#utils": "./src/utils/index.ts",
        "#utils/*": "./src/utils/*.ts",
        "#assets/*": "./src/assets/*",
        "#types": "./src/types/index.ts",
        "#types/*": "./src/types/*.ts"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "bin": {
        "goblin-malin": "dist/cli.js"
    },
    "files": [
        "dist",
        "README.md",
        "scripts/save-install-source.mjs"
    ],
    "scripts": {
        "dev": "tsx src/cli.ts",
        "start": "ts-node src/index.ts",
        "build": "tsup",
        "type-check": "tsc --noEmit",
        "probe:songlink": "node scripts/songlink-rate-probe.mjs",
        "test:spotify-url-info": "node scripts/spotify-url-info-test.mjs",
        "lint": "eslint src/",
        "format": "prettier --write src/",
        "format:check": "prettier --check src/",
        "postinstall": "node scripts/save-install-source.mjs",
        "package:win": "node scripts/build-sea.mjs",
        "prepack": "node scripts/patch-readme.mjs",
        "postpack": "git checkout -- README.md",
        "prepublishOnly": "tsup"
    },
    "keywords": [
        "music",
        "download",
        "downloader",
        "tui",
        "cli",
        "terminal",
        "spotify",
        "youtube",
        "yt-dlp",
        "metadata",
        "tags",
        "ink",
        "react"
    ],
    "author": "Tetraxel",
    "license": "SEE LICENSE IN LICENSE",
    "pkg": {
        "assets": [
            "node_modules/yoga-layout/dist/binaries/yoga-wasm-base64-esm.js"
        ]
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Tetraxel/goblin-malin.git"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@swc/core": "^1.10.0",
        "@types/adm-zip": "^0.5.7",
        "@types/dotenv": "^8.2.3",
        "@types/ink": "^2.0.3",
        "@types/ink-select-input": "^3.0.5",
        "@types/ink-spinner": "^3.0.5",
        "@types/ink-text-input": "^2.0.5",
        "@types/node": "^25.6.2",
        "@types/react": "^19.2.14",
        "@yao-pkg/pkg": "^6.20.0",
        "eslint": "^9.39.4",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "postject": "^1.0.0-alpha.6",
        "prettier": "^3.8.3",
        "ts-node": "^10.9.2",
        "tsup": "^8.0.0",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.3"
    },
    "dependencies": {
        "7zip-bin": "^5.2.0",
        "@spotify/web-api-ts-sdk": "^1.2.0",
        "adm-zip": "^0.5.17",
        "chalk": "^5.6.2",
        "clipboardy": "^5.3.1",
        "dotenv": "^17.4.2",
        "flac-tagger": "^2.0.0",
        "flat-cache": "^6.1.22",
        "fullscreen-ink": "^0.1.0",
        "ink": "^7.0.2",
        "ink-big-text": "^2.0.0",
        "ink-form": "^2.0.1",
        "ink-gradient": "^4.0.0",
        "ink-link": "^5.0.0",
        "ink-picture": "^1.3.5",
        "ink-select-input": "^6.2.0",
        "ink-spinner": "^5.0.0",
        "ink-text-input": "^6.0.0",
        "musicbrainz-api": "^1.2.1",
        "node-id3": "^0.2.9",
        "open": "^11.0.0",
        "react": "^19.2.6",
        "slsk-client": "^1.1.0",
        "spotify-url-info": "^3.3.0",
        "winston": "^3.19.0",
        "winston-transport": "^4.9.0",
        "ytdlp-nodejs": "^3.4.4",
        "ytmusic-api": "^5.3.1"
    }
}
